# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Site URL (optional, has fallback)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Anthropic API — powers the Brand Pulse Check tool on /ai
ANTHROPIC_API_KEY=your_anthropic_api_key

# n8n webhook URLs — form submissions and automations
N8N_WEBHOOK_URL=your_n8n_webhook_url
N8N_SUBSCRIBE_WEBHOOK_URL=your_n8n_subscribe_webhook_url
N8N_CAREERS_WEBHOOK_URL=your_n8n_careers_webhook_url
N8N_BRAND_PULSE_WEBHOOK_URL=your_n8n_brand_pulse_webhook_url
